---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" activePage="home">
  <!-- Added responsive padding and reduced gap for better flow -->
  <div class="flex flex-col md:flex-row items-center md:items-start gap-6 md:gap-10">
    
    <!-- Image implementation -->
    <div class="w-60 h-60 rounded-full overflow-hidden flex-shrink-0">
  		 <img src="/me.jpeg" alt="Profile" class="w-full h-full object-cover" />
	</div>
    
    <!-- Reduced font size for a cleaner look -->
    <div class="space-y-3 text-center md:text-left">
      <h1 class="text-xl md:text-2xl font-bold">Aadya Gupta</h1>
      <p class="text-sm md:text-base opacity-90 leading-relaxed">
        Researcher interested in Mechanistic Interpretability, specifically focusing on last-token hidden representations.
      </p>
    </div>
  </div>

  <hr class="my-12 border-ink/30" />

  <section class="text-sm md:text-base leading-relaxed">
    <h2 class="text-lg font-bold mb-4">Latest Updates</h2>
    <p class="opacity-90">Welcome to my research space. Here I document my work on logic decay and representation analysis.</p>
  </section>
</BaseLayout>