---
import '../styles/global.css';
const { title, activePage } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Aadya</title>
  </head>
  <body class="bg-paper text-ink min-h-screen font-mono py-8 md:py-12">
    <!-- Changed px-6 to px-4 for mobile, md:px-12 for larger screens -->
    <div class="px-4 md:px-12">
      
      <!-- Added flex-wrap and gap-4/6 for mobile spacing -->
      <nav class="flex flex-wrap justify-end gap-x-6 gap-y-2 mb-12 md:mb-16 text-base md:text-lg">
        {activePage !== 'home' && <a href="/">Home</a>}
        {activePage !== 'blog' && <a href="/blog">Blog</a>}
        {activePage !== 'lab' && <a href="/lab">Lab</a>}
        <a href="/cv.pdf" target="_blank">CV</a>
        <a href="https://github.com/aadya-gupta">Github</a>
      </nav>
      
      <main class="max-w-4xl mx-auto w-full">
        <slot />
      </main>
    </div>
  </body>
</html>